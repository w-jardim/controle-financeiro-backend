{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "backend/src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "backend/node_modules/**",
    ".git"
  ]
}