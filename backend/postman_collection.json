{
  "info": {
    "name": "API Gestão de CT - Completa",
    "_postman_id": "gestao-ct-final",
    "description": "Collection completa com Auth, Status, CTs, Alunos e Transações.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "ctId", "value": "" },
    { "key": "alunoId", "value": "" },
    { "key": "transacaoId", "value": "" }
  ],

  "item": [

    {
      "name": "Status",
      "item": [
        { "name": "Raiz", "request": { "method": "GET", "url": "{{baseUrl}}/" } },
        { "name": "Saúde", "request": { "method": "GET", "url": "{{baseUrl}}/saude" } },
        { "name": "Ping", "request": { "method": "GET", "url": "{{baseUrl}}/ping" } },
        { "name": "Teste Banco", "request": { "method": "GET", "url": "{{baseUrl}}/teste-banco" } }
      ]
    },

    {
      "name": "Auth",
      "item": [
        {
          "name": "Cadastro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/cadastro",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeResponsavel\": \"Wallace\",\n  \"email\": \"wallace@email.com\",\n  \"senha\": \"123456\",\n  \"nomeAccount\": \"CT Wallace\",\n  \"tipoAccount\": \"ct_owner\",\n  \"nomeCtInicial\": \"CT Inicial\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.collectionVariables.set('token', json.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"senha\": \"teste12345678\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "CTs",
      "item": [
        {
          "name": "Criar CT",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.collectionVariables.set('ctId', json.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/cts",
            "body": { "mode": "raw", "raw": "{ \"nome\": \"CT Teste\" }" }
          }
        },
        {
          "name": "Listar CTs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cts"
          }
        }
      ]
    },

    {
      "name": "Alunos",
      "item": [
        {
          "name": "Criar Aluno",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.collectionVariables.set('alunoId', json.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/alunos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"ct_id\": {{ctId}},\n  \"telefone\": \"21999999999\",\n  \"email\": \"joao@email.com\",\n  \"cpf\": null,\n  \"data_nascimento\": null,\n  \"sexo\": null,\n  \"nome_responsavel\": null,\n  \"telefone_responsavel\": null\n}"
            }
          }
        },
        {
          "name": "Listar Alunos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/alunos"
          }
        }
      ]
    },

    {
      "name": "Transações",
      "item": [
        {
          "name": "Criar Transação",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.collectionVariables.set('transacaoId', json.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/transacoes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"receita\",\n  \"descricao\": \"Mensalidade\",\n  \"valor\": 150,\n  \"ct_id\": {{ctId}}\n}"
            }
          }
        },
        {
          "name": "Resumo Geral",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/transacoes/resumo"
          }
        }
      ]
    }

  ]
}