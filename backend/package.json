{
  "name": "gestao-ct-financeiro-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon -L src/index.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:ci": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "db:test:up": "docker compose -f ../docker-compose.test.yml up -d",
    "db:test:down": "docker compose -f ../docker-compose.test.yml down -v",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test:with-db": "npm run db:test:up && powershell -Command \"$id = docker compose -f ../docker-compose.test.yml ps -q mysql_test; while ((docker inspect -f '{{.State.Health.Status}}' $id) -ne 'healthy') { Start-Sleep -Seconds 1 }\" && npm test && npm run db:test:down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^5.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  }
}
