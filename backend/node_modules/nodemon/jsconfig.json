{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "backend/src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "backend/node_modules",
    ".git"
  ]
}